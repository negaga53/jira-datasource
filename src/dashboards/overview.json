      "title": "Total Open Issues",
      "type": "stat",
      "targets": [
        {
          "refId": "A",
          "queryType": "jql_search",
          "jql": "project = $project AND status != Done"
        }
      ]
    },
    {
      "datasource": {
        "type": "jira-datasource",
