      "type": "timeseries",
      "targets": [
        {
          "refId": "A",
          "queryType": "issue_count",
          "jql": "project = $project AND created >= -30d",
          "interval": "1d"
        }
      ]
    },
    {
      "datasource": {
        "type": "jira-datasource",
        "uid": "${DS_JIRA}"
      },
