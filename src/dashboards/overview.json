      "type": "table",
      "targets": [
        {
          "refId": "A",
          "queryType": "cycle_time",
          "jql": "project = $project AND status = Done",
          "startStatus": "In Progress",
          "endStatus": "Done",
          "quantile": 85
        }
      ]
    },
    {
      "datasource": {
        "type": "jira-datasource",
